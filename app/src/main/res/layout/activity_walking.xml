<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/milk">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Toolbar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Walking"
            android:textColor="@color/darkGreen"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Hero Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_green"
            android:padding="28dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚶"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/tv_steps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/milk"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="steps today"
                android:textColor="@color/lightBrown"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal: 10,000 steps"
                android:textColor="@color/milk"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <ProgressBar
                android:id="@+id/progress_steps"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progressTint="@color/lightBrown"
                android:progressBackgroundTint="@color/darkGreen"
                android:max="10000"
                android:progress="0" />

        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Distance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 km"
                    android:textColor="@color/darkGreen"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Duration -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 min"
                    android:textColor="@color/darkGreen"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duration"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Calories -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 kcal"
                    android:textColor="@color/darkGreen"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_stat_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="24sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking your steps automatically. Keep your phone with you while walking."
                android:textColor="@color/darkGreen"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- Weekly Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weekly progress"
            android:textColor="@color/darkGreen"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Weekly Bar Chart (static visual) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_stat_card"
            android:padding="16dp"
            android:gravity="bottom"
            android:layout_marginBottom="24dp">

            <!-- Mon -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="40dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Tue -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="55dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Wed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="70dp"
                    android:background="@color/caramel"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="W"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Thu -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="45dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Fri -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="60dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Sat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="35dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Sun -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="16dp"
                    android:layout_height="50dp"
                    android:background="@color/lightGreen"
                    android:layout_gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S"
                    android:textColor="@color/caramel"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>