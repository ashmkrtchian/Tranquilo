<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SecondFragment"
    android:background="@color/milk"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:gravity="center"
    android:paddingTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="16dp"
        android:layout_marginTop="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tranquilo"
            android:textSize="34sp"
            android:textColor="#2C2820"
            android:textStyle="italic"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="what will you explore today?"
            android:textSize="13sp"
            android:textColor="#9B958D"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/music"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/lightGreen">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/musicIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="♪"
                            android:textSize="22sp"
                            android:textColor="#1E3211"
                            android:alpha="0.5"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/musicLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/music"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/musicHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/musicHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="relax &amp; listen"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/poetryLabel"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/caramel">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦"
                            android:textSize="22sp"
                            android:textColor="#3A2410"
                            android:alpha="0.5"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/poetry"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/poetryHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/poetryHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="words &amp; wonder"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/schulteTable"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/lightBrown">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⊞"
                            android:textSize="22sp"
                            android:textColor="#2E1C08"
                            android:alpha="0.5"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/schulteLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Schulte Table"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/schulteHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/schulteHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="focus training"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/moodTracking"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/darkGreen">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="◈"
                            android:textSize="22sp"
                            android:textColor="#162409"
                            android:alpha="0.5"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/walkingLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mood Tracking"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/walkingHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/walkingHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track your mood daily"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/podcast"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/caramel">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.5"
                            android:text="◎"
                            android:textColor="#3A2410"
                            android:textSize="22sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/podcastLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Podcast"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/podcastHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/podcastHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="stories &amp; talks"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/breath"
                    android:layout_width="0dp"
                    android:layout_height="155dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/lightGreen">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❋"
                            android:textSize="22sp"
                            android:textColor="@color/milk"
                            android:alpha="0.5"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/breathLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Breath"
                            android:textSize="17sp"
                            android:textColor="@color/milk"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/breathHint"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/breathHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="calm your mind"
                            android:textSize="11sp"
                            android:textColor="@color/milk"
                            android:alpha="0.65"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>