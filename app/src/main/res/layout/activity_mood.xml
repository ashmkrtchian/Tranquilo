<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/milk"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="20dp"
        android:paddingBottom="40dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_circle_light_green"
            android:contentDescription="Back"
            android:layout_gravity="start"
            app:tint="@color/milk" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOOD"
            android:textColor="@color/lightGreen"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How are you\nfeeling today?"
            android:textColor="@color/darkGreen"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select the mood that best describes\nhow you feel right now."
            android:textColor="@color/caramel"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="36dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="@color/lightGreen"
            android:layout_marginBottom="36dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_happy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Happy"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Joyful · Grateful"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_calm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calm"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peaceful · Relaxed"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_anxious"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anxious"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Worried · Tense"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_sad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sad"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low · Heavy"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_tired"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tired"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drained · Sleepy"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_focused"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focused"
                    android:textColor="@color/darkGreen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sharp · Present"
                    android:textColor="@color/caramel"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </GridLayout>

        <LinearLayout
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_green"
            android:padding="28dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="@color/lightBrown"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_selected_mood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/milk"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_mood_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/milk"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_streak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_stat_card"
            android:padding="20dp"
            android:visibility="gone"
            android:layout_marginVertical="20dp">

            <TextView
                android:id="@+id/tv_streak_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/darkGreen"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_streak_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="day streak"
                android:textColor="@color/lightGreen"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="4dp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>