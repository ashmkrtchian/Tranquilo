<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/lightGreen"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Icon background circle -->
        <FrameLayout
            android:id="@+id/iconFrame"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_dark">

            <!-- Default music note icon -->
            <ImageView
                android:id="@+id/ivMusicNote"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_music_note"
                app:tint="@color/lightBrown" />

            <!-- Equalizer icon shown when track is playing -->
            <ImageView
                android:id="@+id/ivPlaying"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_equalizer"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Title, Composer, Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iconFrame"
            android:layout_toStartOf="@id/btnPlay"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/milk"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvComposer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lightBrown"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/milk"
                android:alpha="0.5"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Play button -->
        <ImageView
            android:id="@+id/btnPlay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_caramel"
            android:src="@drawable/play"
            android:padding="8dp"
            android:contentDescription="Play"
            app:tint="@color/milk" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>