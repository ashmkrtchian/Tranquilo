<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/milk">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/darkGreen"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/milk" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textColor="@color/milk"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Calm Minds of All Time"
            android:textColor="@color/lightBrown"
            android:textSize="14sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/podiumSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/lightGreen"
        android:paddingTop="24dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="8dp"
        android:gravity="bottom">

        <LinearLayout
            android:id="@+id/podium2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/avatar2"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg_caramel" />

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="2"
                    android:textColor="@color/milk"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/rank_badge_caramel"
                    android:layout_gravity="bottom|end" />
            </FrameLayout>

            <TextView
                android:id="@+id/name2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/milk"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/coins2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— 🪙"
                android:textColor="@color/lightBrown"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Podium block -->
            <View
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/caramel"
                android:layout_marginTop="10dp"
                android:alpha="0.85" />
        </LinearLayout>

        <!-- 1st Place -->
        <LinearLayout
            android:id="@+id/podium1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">


            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/avatar1"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg_lightbrown" />

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="1"
                    android:textColor="@color/darkGreen"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/rank_badge_gold"
                    android:layout_gravity="bottom|end" />
            </FrameLayout>

            <TextView
                android:id="@+id/name1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/milk"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/coins1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— 🪙"
                android:textColor="@color/lightBrown"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:background="@color/lightBrown"
                android:layout_marginTop="10dp"
                android:alpha="0.9" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/podium3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/avatar3"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg_caramel" />

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="3"
                    android:textColor="@color/milk"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/rank_badge_caramel"
                    android:layout_gravity="bottom|end" />
            </FrameLayout>

            <TextView
                android:id="@+id/name3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/milk"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/coins3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— 🪙"
                android:textColor="@color/lightBrown"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:background="@color/caramel"
                android:layout_marginTop="10dp"
                android:alpha="0.75" />
        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        android:indeterminateTint="@color/lightGreen"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>