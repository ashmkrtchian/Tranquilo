<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Rain"
    android:orientation="vertical"
    android:background="@color/darkGreen"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp"
    android:paddingTop="50dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        app:tint="@color/milk" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAIN SOUNDS"
            android:textColor="@color/milk"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:textAllCaps="true"
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="32dp"
            app:cardBackgroundColor="@color/lightGreen"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:src="@drawable/rain"
                    android:scaleType="centerCrop"
                    android:padding="3dp"
                    app:shapeAppearanceOverlay="@style/CircleImageStyle"
                    app:strokeColor="@color/lightBrown"
                    app:strokeWidth="3dp"
                    android:layout_marginBottom="28dp"/>

                <SeekBar
                    android:id="@+id/seekBarPosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0"
                    android:progressTint="@color/milk"
                    android:thumbTint="@color/lightBrown"
                    android:progressBackgroundTint="@color/darkGreen"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/elapsedTimeView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0:00"
                        android:textColor="@color/milk"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/remainingTimeView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0:00"
                        android:textColor="@color/milk"
                        android:textSize="13sp"
                        android:gravity="end"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnPlay"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/play"
                    android:background="@drawable/circle_button_bg"
                    android:layout_marginTop="24dp"
                    android:onClick="setBtnPlay"
                    android:elevation="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="28dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sound"
                        android:alpha="0.8"/>

                    <SeekBar
                        android:id="@+id/volumeBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        android:progress="50"
                        android:progressTint="@color/milk"
                        android:thumbTint="@color/lightBrown"
                        android:progressBackgroundTint="@color/darkGreen"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sound2"
                        android:alpha="0.8"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>