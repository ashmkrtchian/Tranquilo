<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/darkGreen"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_surface"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="@color/milk" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRANQUILO"
                android:textColor="@color/lightBrown"
                android:textSize="10sp"
                android:letterSpacing="0.3"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Classical Music"
                android:textColor="@color/milk"
                android:textSize="26sp"
                android:textStyle="italic"
                android:fontFamily="serif" />
        </LinearLayout>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_search_bar"
            android:hint="Search composer or piece…"
            android:textColor="@color/darkGreen"
            android:textSize="14sp"
            android:paddingStart="48dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignStart="@+id/etSearch"
            android:layout_alignParentTop="true"
            android:layout_marginStart="18dp"
            android:layout_marginTop="14dp"
            android:contentDescription="Search icon"
            android:src="@drawable/search"
            app:tint="@color/lightGreen" />
    </RelativeLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardNowPlaying"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/lightGreen"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:src="@drawable/ic_music_note"
                android:scaleType="centerInside"
                android:padding="20dp"
                android:layout_marginBottom="12dp"
                app:tint="@color/lightBrown" />

            <TextView
                android:id="@+id/tvNowPlayingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/milk"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvNowPlayingComposer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lightBrown"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Playback Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <ImageView
                    android:id="@+id/btnPrev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_skip_previous"
                    android:contentDescription="Previous"
                    android:padding="5dp"
                    app:tint="@color/milk" />

                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_caramel"
                    android:src="@drawable/stop"
                    android:padding="5dp"
                    android:contentDescription="Play/Pause"
                    app:tint="@color/milk" />

                <ImageView
                    android:id="@+id/btnNext"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_skip_next"
                    android:padding="5dp"
                    android:contentDescription="Next"
                    app:tint="@color/milk" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Section Label -->
    <TextView
        android:id="@+id/tvListLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="Featured Pieces"
        android:textColor="@color/lightBrown"
        android:textSize="11sp"
        android:letterSpacing="0.12" />

    <!-- Track List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTracks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false" />

</LinearLayout>