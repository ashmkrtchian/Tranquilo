<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/milk"
    android:scrollbars="none"
    android:paddingTop="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="B R E A T H E"
                android:textSize="12sp"
                android:textColor="@color/lightGreen"
                android:letterSpacing="0.3"/>

            <LinearLayout
                android:id="@+id/coinsBadge"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_coin_badge"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1FA99;"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/coinCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="13sp"
                    android:textColor="@color/milk"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/breathBall"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/lungs"
                android:scaleType="fitCenter"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/breathState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="17sp"
                android:textColor="@color/darkGreen"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/breathTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/lightGreen"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="36dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startButton"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:text="START"
                android:textColor="@color/milk"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="@color/lightGreen"
                app:cornerRadius="26dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/lightGreen"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TECHNIQUE"
                android:textSize="11sp"
                android:textColor="@color/lightGreen"
                android:letterSpacing="0.3"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="36dp"
            android:paddingStart="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardBox"
                    android:layout_width="120dp"
                    android:layout_height="112dp"
                    android:background="@drawable/bg_technique_card_active"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="10dp"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9632;"
                        android:textSize="24sp"
                        android:textColor="@color/lightGreen"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Box"
                        android:textSize="14sp"
                        android:textColor="@color/darkGreen"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4&#xB7;4&#xB7;4&#xB7;4"
                        android:textSize="11sp"
                        android:textColor="@color/lightGreen"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card478"
                    android:layout_width="120dp"
                    android:layout_height="112dp"
                    android:background="@drawable/bg_technique_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="10dp"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F319;"
                        android:textSize="24sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4-7-8"
                        android:textSize="14sp"
                        android:textColor="@color/darkGreen"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep"
                        android:textSize="11sp"
                        android:textColor="@color/lightGreen"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardCalm"
                    android:layout_width="120dp"
                    android:layout_height="112dp"
                    android:background="@drawable/bg_technique_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="10dp"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F343;"
                        android:textSize="24sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm"
                        android:textSize="14sp"
                        android:textColor="@color/darkGreen"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4&#xB7;6"
                        android:textSize="11sp"
                        android:textColor="@color/lightGreen"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSigh"
                    android:layout_width="120dp"
                    android:layout_height="112dp"
                    android:background="@drawable/bg_technique_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4A8;"
                        android:textSize="24sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phys. Sigh"
                        android:textSize="13sp"
                        android:textColor="@color/darkGreen"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fast relief"
                        android:textSize="11sp"
                        android:textColor="@color/lightGreen"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/lightGreen"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SOUNDSCAPE"
                android:textSize="11sp"
                android:textColor="@color/lightGreen"
                android:letterSpacing="0.3"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mix freely"
                android:textSize="11sp"
                android:textColor="@color/caramel"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_sound_panel"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/rainToggle"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_sound_btn_off"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F327;"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rain"
                            android:textSize="13sp"
                            android:textColor="@color/darkGreen"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/rainVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="11sp"
                            android:textColor="@color/lightGreen"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/rainVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/lightGreen"
                        android:thumbTint="@color/caramel"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/oceanToggle"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_sound_btn_off"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F30A;"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ocean"
                            android:textSize="13sp"
                            android:textColor="@color/darkGreen"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/oceanVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="11sp"
                            android:textColor="@color/lightGreen"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/oceanVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/lightGreen"
                        android:thumbTint="@color/caramel"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/fireToggle"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_sound_btn_off"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F525;"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fire"
                            android:textSize="13sp"
                            android:textColor="@color/darkGreen"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/fireVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="11sp"
                            android:textColor="@color/lightGreen"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/fireVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/lightGreen"
                        android:thumbTint="@color/caramel"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/forestToggle"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_sound_btn_off"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F332;"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Forest"
                            android:textSize="13sp"
                            android:textColor="@color/darkGreen"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/forestVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="11sp"
                            android:textColor="@color/lightGreen"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/forestVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/lightGreen"
                        android:thumbTint="@color/caramel"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/lightGreen"
            android:paddingHorizontal="24dp"
            android:paddingVertical="20dp"
            android:layout_marginHorizontal="20dp"
            android:orientation="vertical"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8220;"
                android:textSize="30sp"
                android:textColor="@color/caramel"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/quoteText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breathe deeply, live fully."
                android:textSize="15sp"
                android:textColor="@color/milk"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>